        "template": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Configuration Saved - Smart Pot</title>\n    <!-- Tailwind CSS for styling -->\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <!-- Phosphor Icons for UI icons -->\n    <script src=\"https://unpkg.com/@phosphor-icons/web\"></script>\n    \n    <style>\n        body { font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif; }\n        .hidden { display: none !important; }\n    </style>\n</head>\n<body class=\"bg-slate-50 text-slate-800 selection:bg-green-100 min-h-screen\">\n\n    <!-- Top Navigation Bar -->\n    <nav class=\"bg-white border-b border-gray-200 px-6 py-4 sticky top-0 z-10 shadow-sm\">\n        <div class=\"max-w-5xl mx-auto flex justify-between items-center\">\n            <div class=\"flex items-center space-x-3\">\n                <div class=\"bg-green-500 p-2 rounded-xl text-white flex items-center justify-center\">\n                    <i class=\"ph ph-leaf text-2xl\"></i>\n                </div>\n                <h1 class=\"text-xl font-bold tracking-tight text-gray-900\">Smart Pot Dashboard</h1>\n            </div>\n            \n            <div class=\"flex items-center space-x-4\">\n                <!-- Data Source Status Indicator -->\n                <div class=\"flex items-center space-x-2 text-sm font-medium\">\n                    <span class=\"flex items-center text-emerald-600 bg-emerald-50 px-3 py-1 rounded-full\">\n                        <i class=\"ph ph-database text-base mr-2\"></i> Mock Data\n                    </span>\n                </div>\n            </div>\n        </div>\n    </nav>\n\n    <!-- Main Content -->\n    <main class=\"max-w-5xl mx-auto px-6 py-8\">\n        <!-- Success Message Section -->\n        <section class=\"bg-white rounded-3xl border border-gray-200 shadow-sm overflow-hidden\">\n            <div class=\"p-8 md:p-12 text-center\">\n                <!-- Success Icon -->\n                <div class=\"flex justify-center mb-6\">\n                    <div class=\"bg-emerald-100 p-6 rounded-full text-emerald-600 flex items-center justify-center\">\n                        <i class=\"ph ph-check-circle text-5xl\"></i>\n                    </div>\n                </div>\n\n                <!-- Success Title -->\n                <h2 class=\"text-3xl font-bold text-gray-800 mb-4\">Plant Configuration Saved!</h2>\n                \n                <!-- Success Description -->\n                <p class=\"text-lg text-gray-600 mb-8 max-w-2xl mx-auto\">\n                    Your Smart Pot has been successfully configured with the new plant settings. The care algorithms will now adjust to provide optimal conditions for your plant.\n                </p>\n\n                <!-- Configuration Details -->\n                <div class=\"bg-gray-50 rounded-2xl p-6 mb-8 max-w-md mx-auto\">\n                    <h3 class=\"text-sm font-semibold text-gray-500 uppercase tracking-wider mb-4\">Configuration Details</h3>\n                    <div class=\"space-y-3 text-left\">\n                        <div class=\"flex justify-between items-center py-2 border-b border-gray-200\">\n                            <span class=\"text-sm text-gray-600\">Plant Type:</span>\n                            <span id=\"selected-plant\" class=\"font-medium text-gray-800\">Loading...</span>\n                        </div>\n                        <div class=\"flex justify-between items-center py-2 border-b border-gray-200\">\n                            <span class=\"text-sm text-gray-600\">Configuration ID:</span>\n                            <span id=\"config-id\" class=\"font-mono text-sm text-gray-800\">Loading...</span>\n                        </div>\n                        <div class=\"flex justify-between items-center py-2\">\n                            <span class=\"text-sm text-gray-600\">Saved At:</span>\n                            <span id=\"saved-time\" class=\"font-medium text-gray-800\">Loading...</span>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Action Buttons -->\n                <div class=\"flex flex-col sm:flex-row gap-4 justify-center items-center\">\n                    <a href=\"Dashboard.html\" class=\"flex items-center space-x-2 px-8 py-3 rounded-xl font-medium transition-all shadow-sm bg-green-600 text-white hover:bg-green-700 hover:shadow-md\">\n                        <i class=\"ph ph-arrow-left text-lg\"></i>\n                        <span>Back to Dashboard</span>\n                    </a>\n                    \n                    <button onclick=\"window.print()\" class=\"flex items-center space-x-2 px-8 py-3 rounded-xl font-medium transition-all border border-gray-300 bg-white text-gray-700 hover:bg-gray-50\">\n                        <i class=\"ph ph-printer text-lg\"></i>\n                        <span>Print Confirmation</span>\n                    </button>\n                </div>\n\n                <!-- Additional Info -->\n                <div class=\"mt-8 text-sm text-gray-500 bg-blue-50 p-4 rounded-lg border border-blue-100 max-w-2xl mx-auto\">\n                    <p class=\"flex items-start\">\n                        <i class=\"ph ph-info text-blue-500 mr-2 mt-0.5\"></i>\n                        <span>Your plant configuration has been saved to the Smart Pot's memory. The system will now monitor and adjust environmental conditions based on your plant's specific needs.</span>\n                    </p>\n                </div>\n            </div>\n        </section>\n    </main>\n\n    <script>\n        // Parse URL parameters to get form data\n        function getUrlParams() {\n            const params = new URLSearchParams(window.location.search);\n            const formData = {};\n            \n            // Try to get data from URL parameters or localStorage\n            const plant = params.get('plant') || localStorage.getItem('lastPlant');\n            const plantName = params.get('plantName') || localStorage.getItem('lastPlantName');\n            \n            if (plant) formData.plant = plant;\n            if (plantName) formData.plantName = plantName;\n            \n            return formData;\n        }\n\n        // Update the page with configuration details\n        function updateSuccessPage() {\n            const formData = getUrlParams();\n            \n            // Update plant name\n            const plantElement = document.getElementById('selected-plant');\n            if (formData.plantName) {\n                plantElement.textContent = formData.plantName;\n            } else {\n                plantElement.textContent = 'Unknown Plant';\n            }\n            \n            // Generate configuration ID\n            const configId = 'CFG-' + Date.now().toString(36).toUpperCase();\n            document.getElementById('config-id').textContent = configId;\n            \n            // Set saved time\n            const now = new Date();\n            document.getElementById('saved-time').textContent = now.toLocaleString();\n            \n            // Store in localStorage for reference\n            localStorage.setItem('lastPlant', formData.plant || '');\n            localStorage.setItem('lastPlantName', formData.plantName || '');\n            localStorage.setItem('lastConfigId', configId);\n            localStorage.setItem('lastSavedTime', now.toISOString());\n        }\n\n        // Initialize page\n        document.addEventListener('DOMContentLoaded', updateSuccessPage);\n    </script>\n</body>\n</html>\n",
